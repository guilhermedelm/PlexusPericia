<script>
  // Função auxiliar com Arrow Function e Template Literals
  const buildWAUrl = (perfil, selected, phone) => {
    const baseUrl = "https://wa.me/556130342602?text=";
    let mensagem = `Olá, sou ${perfil}. Meu momento: ${selected}.`;
    
    if (phone) {
      mensagem += ` Meu número: ${phone}`;
    }
    
    return baseUrl + encodeURIComponent(mensagem);
  };



  // Aguarda o Astro carregar a página (se estiver usando View Transitions)
document.addEventListener('DOMContentLoaded', () => {
  
  // 1. Referencia o formulário inteiro
  const form = document.getElementById('meuFormularioLumen');

  // Verifica se o formulário existe na página atual
  if (form) {
    form.addEventListener('submit', (event) => {
      // Evita o recarregamento da página
      event.preventDefault();

      // 2. Referencia cada input individualmente pelo ID
      const inputTelefone = document.getElementById('telefone');
      const selectProfissao = document.getElementById('profissao');
      const selectMomento = document.getElementById('momento');
      const checkboxPrivacidade = document.getElementById('privacidade');
      const alertaErro = document.getElementById('alertaErro'); // Para manipular avisos

      // 3. Extrai os valores digitados/selecionados pelo usuário
      const dadosDoFormulario = {
        telefone: inputTelefone.value,
        profissao: selectProfissao.value,
        momento: selectMomento.value,
        // Atenção: checkbox usa .checked (retorna true ou false), e não .value
        aceitouPrivacidade: checkboxPrivacidade.checked 
      };

      // Mostra no console para você ver que está funcionando!
      console.log('Dados capturados:', dadosDoFormulario);
      var temErro = false; // Variável para controlar se há erro
      // --- AQUI VOCÊ PODE ADICIONAR SUA LÓGICA DE VALIDAÇÃO ---
      // Exemplo rápido: Se o nome estiver vazio


      // if (!dadosDoFormulario.telefone) {
      //     inputTelefone.closest('.form-group').classList.add('error-state');
      //     temErro = true;
      //     console.log('Erro: Telefone é obrigatório.');
      // } else {
      //     inputTelefone.closest('.form-group').classList.remove('error-state');
      // }

      if (!dadosDoFormulario.profissao) {
          selectProfissao.closest('.form-group').classList.add('error-state');
          temErro = true;
          console.log('Erro: Profissão é obrigatória.');
      } else {
          selectProfissao.closest('.form-group').classList.remove('error-state');
      }


      if (!dadosDoFormulario.momento) {
          selectMomento.closest('.form-group').classList.add('error-state');
          temErro = true;
          console.log('Erro: Esfera é obrigatória.');
      } else {
          selectMomento.closest('.form-group').classList.remove('error-state');
      }



      if (!dadosDoFormulario.aceitouPrivacidade) {
          checkboxPrivacidade.closest('.checkbox-group').classList.add('error-state'); // Você pode precisar ajustar o CSS para esse erro específico
          alertaErro.style.display = 'block';        
          temErro = true;
          console.log('Erro: Você deve aceitar a política de privacidade.');
        }

        // Se houver erro, mostra o alerta geral e interrompe
        if (temErro) {
            alertaErro.style.display = 'block';
            return;
        }

        // Se chegou até aqui, está tudo certo! Oculta o erro.
        alertaErro.style.display = 'none';
        console.log('Formulário validado com sucesso!', dadosDoFormulario);


      if (typeof window !== 'undefined' && typeof window['gtag_report_conversion'] === 'function') {
        window['gtag_report_conversion']();
        console.log('Evento do Google Ads disparado com sucesso!');
      } else {
      console.warn('Função do Google Ads não encontrada.');
      }


      if (typeof fbq !== 'undefined') {
        fbq('track', 'Lead', {
          content_name: 'Formulario Qualificacao Plexus'
        });
        console.log('Evento do Facebook Pixel disparado com sucesso!')
      }
      else {
        console.warn('Função do Facebook Pixel não encontrada.');
      }



      const url = buildWAUrl(
        dadosDoFormulario.profissao,
        dadosDoFormulario.momento,
        dadosDoFormulario.telefone
      );
      window.location.href = url;
    });
  }
});



  // Função principal usando ES6+
  const initQualForm = (tabId, perfil) => {
    const opts = document.querySelectorAll(`#qopts-${tabId} .qual-opt`);
    const cta = document.getElementById(`qcta-${tabId}`);
    const phoneGroup = document.getElementById(`qphone-group-${tabId}`);
    const phoneInput = document.getElementById(`qphone-${tabId}`);
    let selected = null;

    // Guard clause: se não encontrar as opções na página atual, encerra a função
    // Isso evita erros no console em páginas que não têm esse formulário
    if (!opts.length) return;

    opts.forEach((opt) => {
      opt.addEventListener('click', () => {
        // Remove classe 'selected' de todos e adiciona no clicado
        opts.forEach((o) => o.classList.remove('selected'));
        opt.classList.add('selected');
        
        selected = opt.dataset.val;

        // Atualiza a UI
        if (phoneGroup) phoneGroup.style.display = 'block';
        if (cta) {
          cta.style.pointerEvents = 'auto';
          cta.style.opacity = '1';
          cta.href = buildWAUrl(perfil, selected, phoneInput ? phoneInput.value : '');
        }
      });
    });

    if (phoneInput) {
      phoneInput.addEventListener('input', () => {
        if (selected && cta) {
          cta.href = buildWAUrl(perfil, selected, phoneInput.value);
        }
      });
    }

    if (cta) {
      cta.addEventListener('click', (e) => {
        if (!selected) { 
          e.preventDefault(); 
          return;
        }
        
        // Disparo do evento do GTM
        if (window.dataLayer) {
          window.dataLayer.push({
            event: 'lead_qualificado',
            perfil: perfil,
            momento: selected,
            tem_telefone: !!(phoneInput && phoneInput.value)
          });
        }
      });
    }
  };

  // O SEGREDO DO ASTRO: 
  // Usa 'astro:page-load' em vez de 'DOMContentLoaded'
  // Isso garante que o script rode mesmo se o usuário navegar via View Transitions
  document.addEventListener('astro:page-load', () => {
    initQualForm('adv', 'Advogado(a)/Escritório');
    initQualForm('pac', 'Parte com advogado / Sem advogado');
    initQualForm('med', 'Médico(a)/Clínica/Hospital');
  });
</script>