<section class="audience section-padding">
    <div class="container">
        <div class="audience-header reveal" style="text-align:center">
            <span class="section-tag" > Atendimento Especializado</span>
            <h4 class="audience-title">Selecione seu perfil</h4>
            <p class="audience-subtitle">Seja você advogado, <strong>empresa</strong>, paciente ou médico, temos a solução técnica certa para o seu caso.</p>
        </div>

        <!-- Seletor de perfil -->
        <div class="reveal" data-delay="80">
            <span class="audience-sou-um"></span>
        </div>
        <div class="audience-tabs-wrapper reveal" data-delay="100">
            <div class="audience-tabs">
                <button class="audience-tab active" data-tab="advogado">
                    <svg class="icon"><use href="/icons.svg#scale-balanced"/></svg>
                    Sou Advogado
                </button>
                <button class="audience-tab" data-tab="paciente">
                    <svg class="icon"><use href="/icons.svg#user-doctor"/></svg>
                    Sou Paciente
                </button>
                <button class="audience-tab" data-tab="clinica">
                    <svg class="icon"><use href="/icons.svg#heart-pulse"/></svg>
                    Sou Médico / Clínica
                </button>
            </div>
        </div>

        <!-- Painéis de conteúdo -->
        <div class="audience-panels reveal" data-delay="200">

            <!-- PERFIL 1 — ADVOGADO -->
            <div class="audience-panel active" id="panel-advogado">
                <div class="audience-panel-inner">
                    <div class="audience-panel-right">
                        <p class="audience-areas-label">
                            <svg class="icon"><use href="/icons.svg#scale-balanced"/></svg>
                            Áreas de Atuação
                        </p>
                        <ul class="audience-areas-list">
                            <li><span class="area-icon">🏢</span>Defesa de Empresas</li>
                            <li><span class="area-icon">⚖️</span>Causas trabalhistas</li>
                            <li><span class="area-icon">🤝</span>Direito previdenciário</li>
                            <li><span class="area-icon">🩺</span>Erro assistencial / médico</li>
                            <li><span class="area-icon">🛡️</span>Planos de saúde</li>
                            <li><span class="area-icon">🔒</span>Causas securitárias</li>
                            <li><span class="area-icon">⚕️</span>Direito médico</li>
                            <li><span class="area-icon">📋</span>Análise de prontuários</li>
                        </ul>
                        <blockquote class="audience-quote">
                            "Não entregamos apenas laudos. Entregamos <strong>estratégia técnica</strong> aplicada à decisão judicial."
                        </blockquote>
                    </div>
                    <div class="audience-panel-left">
                        <h3 class="audience-panel-h3">Fortaleça sua tese com suporte técnico médico</h3>
                        <p class="audience-panel-desc">Atuamos em conjunto com advogados nas áreas de direito civil | direito médico (Erro Médico), trabalhista, previdenciário, criminal. Erro assistencial, planos de saúde e securitário.</p>
                        <ul class="audience-checklist">
                            <li><svg class="icon audience-check-icon"><use href="/icons.svg#check"/></svg>Formulação de quesitos técnicos estratégicos</li>
                            <li><svg class="icon audience-check-icon"><use href="/icons.svg#check"/></svg>Impugnação fundamentada de laudos periciais</li>
                            <li><svg class="icon audience-check-icon"><use href="/icons.svg#check"/></svg>Tradução da linguagem médica para o Judiciário</li>
                            <li><svg class="icon audience-check-icon"><use href="/icons.svg#check"/></svg>Redução de lacunas e subjetividades periciais</li>
                            <li><svg class="icon audience-check-icon"><use href="/icons.svg#check"/></svg>Análise de viabilidade técnica do caso</li>
                            <li><svg class="icon audience-check-icon"><use href="/icons.svg#check"/></svg>Suporte técnico contínuo ao longo do processo</li>
                            <li><svg class="icon audience-check-icon"><use href="/icons.svg#check"/></svg>Assistência técnica médica pericial completa</li>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- PERFIL 2 — PACIENTE -->
            <div class="audience-panel" id="panel-paciente">
                <div class="audience-panel-inner">
                    <div class="audience-panel-right">
                        <p class="audience-areas-label">
                            <svg class="icon"><use href="/icons.svg#certificate"/></svg>
                            O Que Você Recebe
                        </p>
                        <ul class="audience-areas-list">
                            <li><span class="area-icon">🤝</span>Acompanhamento na perícia</li>
                            <li><span class="area-icon">📄</span>Laudo Médico para PCD | Seguradoras | Fins judiciais</li>
                            <li><span class="area-icon">🔍</span>Análise técnica da documentação</li>
                            <li><span class="area-icon">💬</span>Tradução clara da situação clínica</li>
                            <li><span class="area-icon">🇧🇷</span>Atendimento em todo Brasil</li>
                            <li><span class="area-icon">🔒</span>Absoluto sigilo profissional</li>
                        </ul>
                        <blockquote class="audience-quote">
                            "Cada caso é único. Tratamos o seu com a atenção técnica e humana que ele merece."
                        </blockquote>
                    </div>
                    <div class="audience-panel-left">
                        <h3 class="audience-panel-h3">Seus direitos merecem uma defesa técnica à altura</h3>
                        <p class="audience-panel-desc">Atendemos pessoas físicas que precisam de um parecer médico fundamentado ou assistência técnica em perícias judiciais e administrativas.</p>
                        <ul class="audience-checklist">
                            <li><svg class="icon audience-check-icon"><use href="/icons.svg#check"/></svg>Perícia judicial desfavorável</li>
                            <li><svg class="icon audience-check-icon"><use href="/icons.svg#check"/></svg>Negativa de plano de saúde</li>
                            <li><svg class="icon audience-check-icon"><use href="/icons.svg#check"/></svg>Revisão técnica de laudo pericial desfavorável</li>
                            <li><svg class="icon audience-check-icon"><use href="/icons.svg#check"/></svg>Organização de documentação médica</li>
                            <li><svg class="icon audience-check-icon"><use href="/icons.svg#check"/></svg>Suporte técnico em ações de responsabilidade médica</li>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- PERFIL 3 — MÉDICO / CLÍNICA -->
            <div class="audience-panel" id="panel-clinica">
                <div class="audience-panel-inner">
                    <div class="audience-panel-right">
                        <p class="audience-areas-label">
                            <svg class="icon"><use href="/icons.svg#user-doctor"/></svg>
                            Quem Atendemos
                        </p>
                        <ul class="audience-areas-list">
                            <li><span class="area-icon">🏥</span>Médicos e especialidades</li>
                            <li><span class="area-icon">🏢</span>Hospitais e Clínicas</li>
                            <li><span class="area-icon">🛡️</span>Operadoras de Saúde</li>
                            <li><span class="area-icon">📋</span>Auditoria Médica</li>
                            <li><span class="area-icon">⚖️</span>Processos administrativos</li>
                        </ul>
                        <blockquote class="audience-quote">
                            "Conhecimento clínico e jurídico integrados para proteger sua atuação profissional."
                        </blockquote>
                    </div>
                    <div class="audience-panel-left">
                        <h3 class="audience-panel-h3">Suporte técnico para profissionais e instituições de saúde</h3>
                        <p class="audience-panel-desc">Apoiamos médicos, clínicas, hospitais e operadoras de saúde em processos judiciais, administrativos e de auditoria médica.</p>
                        <ul class="audience-checklist">
                            <li><svg class="icon audience-check-icon"><use href="/icons.svg#check"/></svg>Assistência em processos de erro assistencial</li>
                            <li><svg class="icon audience-check-icon"><use href="/icons.svg#check"/></svg>Auditoria médica e revisão de prontuários</li>
                            <li><svg class="icon audience-check-icon"><use href="/icons.svg#check"/></svg>Pareceres técnicos de defesa</li>
                            <li><svg class="icon audience-check-icon"><use href="/icons.svg#check"/></svg>Tradução médico-jurídica de documentação clínica</li>
                            <li><svg class="icon audience-check-icon"><use href="/icons.svg#check"/></svg>Suporte em processos junto a planos de saúde</li>
                            <li><svg class="icon audience-check-icon"><use href="/icons.svg#check"/></svg>Assessoria técnica em processos administrativos (CRM, ANS)</li>
                        </ul>

                    </div>
                </div>
            </div>

          </div><!-- /audience-panels -->
          <div class="audience-form-spacer" aria-hidden="true"></div>
          <Forms />
            
    </div>
</section>

