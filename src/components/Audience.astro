  <script>
  // 1. Tipamos os parâmetros da URL como strings
  function buildWAUrl(perfil: string, momento: string, telefone: string): string {
    let txt = 'Olá! Vim do site da Plexus Perícias.\n';
    txt += '👤 Perfil: ' + perfil + '\n';
    txt += '📋 Situação: ' + momento + '\n';
    if (telefone) { txt += '📞 Telefone: ' + telefone + '\n'; }
    txt += '\nGostaria de saber mais sobre os serviços.';
    return 'https://wa.me/556130342602?text=' + encodeURIComponent(txt);
  }

  // 2. Tipamos os parâmetros da função inicializadora
  function initQualForm(tabId: string, perfil: string) {
    // Cast para NodeListOf<HTMLElement> para liberar o uso do .dataset
    const opts = document.querySelectorAll('#qopts-' + tabId + ' .qual-opt') as NodeListOf<HTMLElement>;
    
    // Cast para HTMLAnchorElement para liberar o .href
    const cta = document.getElementById('qcta-' + tabId) as HTMLAnchorElement | null;
    
    // Cast para HTMLElement genérico para o .style
    const phoneGroup = document.getElementById('qphone-group-' + tabId) as HTMLElement | null;
    
    // Cast para HTMLInputElement para liberar o .value
    const phoneInput = document.getElementById('qphone-' + tabId) as HTMLInputElement | null;
    
    // Definimos explicitamente o tipo da variável
    let selected: string | null = null;

    opts.forEach(function(opt) {
      opt.addEventListener('click', function() {
        opts.forEach(function(o) { o.classList.remove('selected'); });
        opt.classList.add('selected');
        
        // Pegamos o valor com segurança
        selected = opt.dataset.val || null;
        
        if (phoneGroup) phoneGroup.style.display = 'block';
        
        if (cta && selected) {
          cta.style.pointerEvents = 'auto';
          cta.style.opacity = '1';
          cta.href = buildWAUrl(perfil, selected, phoneInput ? phoneInput.value : '');
        }
      });
    });

    if (phoneInput) {
      phoneInput.addEventListener('input', function() {
        if (selected && cta) {
          cta.href = buildWAUrl(perfil, selected, phoneInput.value);
        }
      });
    }

    if (cta) {
      cta.addEventListener('click', function(e) {
        if (!selected) { 
          e.preventDefault(); 
          return; // Para a execução aqui se nada foi selecionado
        }
        
        // 3. Truque para o GTM: Forçamos o TS a ignorar a tipagem rígida do window
        const w = window as any;
        
        if (w.dataLayer) {
          w.dataLayer.push({
            event: 'lead_qualificado',
            perfil: perfil,
            momento: selected,
            tem_telefone: !!(phoneInput && phoneInput.value)
          });
        }
      });
    }
  }

  // 4. Podemos executar as funções diretamente! O Astro já sabe
  // o momento exato de injetar e rodar esse script na página.
  initQualForm('adv', 'Advogado(a)/Escritório');
  initQualForm('pac', 'Parte com advogado / Sem advogado');
  initQualForm('med', 'Médico(a)/Clínica/Hospital');
</script>


