<script>
  function initAudienceTabs() {
    const tabs = document.querySelectorAll('.audience-tab');
    const panels = document.querySelectorAll('.audience-panel');
    if (!tabs.length) return;

    // 1. Tipamos o targetId como string (ou null, caso o atributo não exista)
    function switchPanel(targetId: string | null) {
      if (!targetId) return; // Proteção extra caso venha vazio

      // 2. Afirmamos que 'next' é um HTMLElement (para liberar o uso de .style)
      const next = document.getElementById('panel-' + targetId) as HTMLElement | null;
      if (!next) return;

      // 3. Trocamos 'var' por 'const'. Isso garante ao TS que 'current'
      // não vai virar null misteriosamente antes do setTimeout rodar!
      const current = document.querySelector('.audience-panel.active') as HTMLElement | null;
      if (current === next) return;

      /* Fade out atual */
      if (current) {
        current.style.transition = 'opacity .22s ease';
        current.style.opacity = '0';
        
        setTimeout(function() {
          current.classList.remove('active');
          current.style.opacity = '';
          current.style.transition = '';
          
          /* Fade in novo */
          next.style.opacity = '0';
          next.style.transition = 'opacity .3s ease';
          next.classList.add('active');
          
          requestAnimationFrame(function() {
            requestAnimationFrame(function() {
              next.style.opacity = '1';
            });
          });
          
          setTimeout(function() {
            next.style.transition = '';
          }, 350);
        }, 230);
      } else {
        next.classList.add('active');
      }
    }

    tabs.forEach(function(tab) {
      tab.addEventListener('click', function() {
        tabs.forEach(function(t) { 
          t.classList.remove('active'); 
        });
        tab.classList.add('active');
        
        // Passamos o valor do atributo (que o TS entende como string | null)
        switchPanel(tab.getAttribute('data-tab'));
      });
    });
  }

  // Inicializa as abas
  initAudienceTabs();
</script>







