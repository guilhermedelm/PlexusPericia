<script>
  function initTintim() {
    // 1. Cast para NodeListOf<HTMLAnchorElement> para liberar a propriedade .dataset
    const waLinks = document.querySelectorAll('a[href*="wa.me"]') as NodeListOf<HTMLAnchorElement>;
    
    waLinks.forEach(function(el) {
      el.addEventListener('click', function() {
        
        // Agora o compilador aceita o dataset sem reclamar
        const label = el.dataset.tintimLabel || document.title;
        
        // 2. Truque mágico: forçamos o TS a ignorar as regras rígidas do window
        const w = window as any;
        
        // Google Tag Manager
        if (w.dataLayer) {
          w.dataLayer.push({ event: 'whatsapp_click', label: label });
        }
        
        // Tintim pixel / TikTok Pixel
        if (w.ttq) {
          w.ttq.track('Contact', { description: label });
        }
      });
    });
  }

  // 3. Executamos diretamente. O Astro garante que o DOM já está pronto!
  initTintim();
</script>


