<script>
  function revealOnScroll() {
    const elements = document.querySelectorAll('.reveal') as NodeListOf<HTMLElement>;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('revealed');
          observer.unobserve(entry.target);
        }
      });
    }, {
      threshold: 0.15,
      rootMargin: '0px 0px -30px 0px'
    });

    elements.forEach((element) => observer.observe(element));
  }

  document.addEventListener('DOMContentLoaded', revealOnScroll);
  window.addEventListener('load', revealOnScroll);

  // 1. Tipamos o parâmetro 'selector' como string
  function applyTilt(selector: string) {
    // 2. Fazemos o cast para NodeListOf<HTMLElement> para liberar o .style nos cards
    const cards = document.querySelectorAll(selector) as NodeListOf<HTMLElement>;
    
    cards.forEach(function(card) {
      // 3. Tipamos 'e' como MouseEvent (é mais limpo e oficial do que criar o objeto à mão)
      card.addEventListener('mousemove', function(e: MouseEvent) {
        const r = card.getBoundingClientRect();
        const x = (e.clientX - r.left) / r.width - 0.5;
        const y = (e.clientY - r.top) / r.height - 0.5;
        const rx = y * -14; 
        const ry = x * 14;
        
        card.style.transition = 'transform .08s ease,box-shadow .1s';
        card.style.transform = 'perspective(800px) rotateX(' + rx + 'deg) rotateY(' + ry + 'deg) translateZ(10px)';
        card.style.boxShadow = (ry < 0 ? '' : '-') + Math.abs(ry) + 'px ' + (-rx) + 'px 28px rgba(247,215,182,.14)';
      });
      
      card.addEventListener('mouseleave', function() {
        card.style.transition = 'transform .45s ease,box-shadow .45s,border-color .3s';
        card.style.transform = '';
        card.style.boxShadow = '';
      });
    });
  }

  // Agora pode chamar a função com segurança, passando as strings dos seletores!
  applyTilt('.service-card');
  applyTilt('.differential-card');
  applyTilt('.problem-card');
  applyTilt('.authority-client-card');
</script>


  /* =============================================
     SCROLL 3D: COUNTER + SECTION DEPTH
  ============================================= */

<script>
  window.addEventListener('scroll',function(){
    var sy=window.scrollY;
    var secs=document.querySelectorAll('section');
    secs.forEach(function(sec){
      var r=sec.getBoundingClientRect();
      var prog=Math.min(1,Math.max(0,-r.top/(r.height*0.6)));
      var rx=prog*2; /* leve inclinação conforme entra na viewport */
      /* apenas estética suave — não aplicar em mobile */
      if(window.innerWidth>1024){
        sec.style.perspectiveOrigin='50% '+(50+prog*5)+'%';
      }
    });
  },{passive:true});
</script>

